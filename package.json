{
  "name": "project-requirements-api",
  "version": "1.0.0",
  "description": "A simple REST API for managing project requirements",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "~5.22.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "prisma": "~5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
